@EndUserText.label: 'Example Access Control for Airport ''US'''
@MappingRole: true
define role ZAC_AIRPORT_US_DE_ODA2026 {
    grant select on ZCDS_AIRPORT_1_ODA2026
                 where Country = 'DE';
    grant select on ZCDS_AIRPORT_2_ODA2026
                 where Country = 'US' or Country = 'DE';             
                        
}